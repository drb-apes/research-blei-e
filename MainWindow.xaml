<Window x:Class="BIMAPES.Matchday.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BIM-APES Matchday Live Capture" Height="700" Width="1200"
        Background="#111111" Foreground="#F5F5F5"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0 0 0 16" Background="#0A0A0A" Padding="12">
            <TextBlock Text="BIM-APES MATCHDAY" FontSize="24" FontWeight="Bold" Foreground="#E0E0E0" />
            <TextBlock Text="Live Biometric Capture" FontSize="16" Margin="20 0 0 0" Foreground="#B0B0B0" VerticalAlignment="Center" />
            <TextBlock Text="●" FontSize="16" Margin="20 0 5 0" Foreground="#00FF00" VerticalAlignment="Center" />
            <TextBlock Text="Live" FontSize="12" Foreground="#00FF00" VerticalAlignment="Center" />
        </StackPanel>

        <!-- Live Capture Table -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Capsules}"
                  AutoGenerateColumns="False"
                  Background="#1A1A1A"
                  Foreground="#F5F5F5"
                  HeadersVisibility="Column"
                  BorderBrush="#333333"
                  AlternatingRowBackground="#0F0F0F"
                  RowHeight="32">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Athlete ID" Binding="{Binding AthleteId}" Width="100" />
                <DataGridTextColumn Header="HR (bpm)" Binding="{Binding HeartRate}" Width="80" />
                <DataGridTextColumn Header="HRV (ms)" Binding="{Binding Hrv}" Width="80" />
                <DataGridTextColumn Header="Accel X" Binding="{Binding AccelX, StringFormat=F2}" Width="80" />
                <DataGridTextColumn Header="Accel Y" Binding="{Binding AccelY, StringFormat=F2}" Width="80" />
                <DataGridTextColumn Header="Accel Z" Binding="{Binding AccelZ, StringFormat=F2}" Width="80" />
                <DataGridTextColumn Header="Speed (m/s)" Binding="{Binding GpsSpeed}" Width="100" />
                <DataGridTextColumn Header="SpO2 (%)" Binding="{Binding SpO2, StringFormat=F1}" Width="80" />
                <DataGridTextColumn Header="GSR (μS)" Binding="{Binding Gsr, StringFormat=F2}" Width="80" />
                <DataGridTextColumn Header="Latency (ms)" Binding="{Binding IngestLatencyMs}" Width="100" />
                <DataGridTextColumn Header="Hash" Binding="{Binding Hash}" Width="120" />
                <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat=HH:mm:ss.fff}" Width="120" />
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>
